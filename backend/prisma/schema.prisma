generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model clinic {
  id                String             @id @default(uuid())
  supabaseId        String
  name              String
  email             String
  accountType       ClinicAccountType?
  status            Boolean?
  profilePictureUrl String?
  createdAt         DateTime           @default(now())

  @@unique([supabaseId, email])
}

enum ClinicAccountType {
  DOCTOR
  RECEPTIONIST
}
